<mapper namespace="com.busanit501.leejj_server_project2.springex_new_0219_keep.mapper.TodoMapper">

    <select id="getTime" resultType="string">
        select now()
    </select>
    <!--    여러 개의 sql 문장을 여기에 등록할 예정-->
    <!--    insert 추가 작업 -->
    <!--    TodoMapper 인터페이스 안에 있는 메서드이름과 동일-->
    <insert id="insert">
        insert into tbl_todo (title, dueDate, writer,finished) values ( #{title}, #{dueDate}, #{writer}, #{finished})
    </insert>

    <select id="selectAll" resultType="com.busanit501.leejj_server_project2.springex_new_0219_keep.domain.TodoVO">
        select * from tbl_todo order by tno desc
    </select>

    <select id="selectOne" resultType="com.busanit501.leejj_server_project2.springex_new_0219_keep.domain.TodoVO">
        select * from tbl_todo where tno = #{ton}
    </select>

    <delete id="delete">
        delete from tbl_todo where tno = #{tno}
    </delete>

    <update id="update">
        update tbl_todo
        set title = #{title},
            dueDate = #{dueDate},
            finished = #{finished}
        where tno = #{tno}
    </update>

